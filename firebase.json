{
  "predeploy": ["npm run bump-assets"],
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": ".",
    "cleanUrls": false,
    "redirects": [
      {
        "source": "/admin.html",
        "destination": "/admin",
        "type": 301
      },
      {
        "source": "/dashboard-elitecard",
        "destination": "/admin.html?viewMode=personal&panel=dashboard",
        "type": 302
      },
      {
        "source": "/dashboard-mascotbook",
        "destination": "/admin.html?viewMode=mascot&panel=dashboard",
        "type": 302
      }
    ],
    "rewrites": [
      {
        "source": "/manifest-user",
        "function": "manifest",
        "region": "us-east1"
      },
      {
        "source": "/card",
        "function": "card",
        "region": "us-east1"
      },
      {
        "source": "/mp/feedback",
        "function": "mercadoPagoFeedback",
        "region": "us-east1"
      },
      {
        "source": "/admin",
        "destination": "/admin.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "firebase-config.example.js"
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "**/*.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "manifest.json",
        "headers": [
          { "key": "Content-Type", "value": "application/manifest+json; charset=utf-8" },
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "sw.js",
        "headers": [
          { "key": "Content-Type", "value": "application/javascript; charset=utf-8" },
          { "key": "Service-Worker-Allowed", "value": "/" },
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "**",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self)" }
        ]
      }
    ]
  }
}
