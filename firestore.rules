rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function mascotAllowedKeys() {
      return [
        'nombre', 'raza', 'sexo', 'salud', 'historia', 'personalidad',
        'mascotId',
        'themeId', 'textureId', 'mascotProTheme', 'tema', 'mascotSurfaceTheme', 'accentColor', 'textColor',
        'fotoPerfilUrl', 'fotoCabeceraUrl', 'galeria', 'galeriaSlots', 'muro',
        'vacunas', 'veterinario', 'fichaCritica', 'visitas', 'likes', 'mascotaPerdida', 'whatsappUrgencia',
        'updatedAt'
      ];
    }

    function personalAllowedKeys() {
      return [
        'user_nombre', 'user_cargo', 'user_empresa', 'user_bio',
        'user_avatarShape', 'user_buttonLayout', 'user_bgColor', 'user_bgPreset',
        'nombreCompleto', 'cargo', 'empresa', 'redes',
        'email', 'telefono', 'whatsappNumero',
        'fotoUrl', 'logoUrl',
        'vcardNombres', 'vcardApellidos', 'vcardOrganizacion', 'vcardTitulo',
        'bio', 'sitioWeb', 'instagram', 'linkedin', 'mapsUrl', 'calendlyUrl',
        'emailInstitucional',
        'updatedAt'
      ];
    }

    /** Solo claves permitidas en tarjeta profesional (sin campos de mascota). */
    function personalCardKeysOk() {
      return request.resource.data.keys().hasOnly(personalAllowedKeys());
    }

    /** Solo claves permitidas en MascotBook (sin campos profesionales mezclados). */
    function mascotCardKeysOk() {
      return request.resource.data.keys().hasOnly(mascotAllowedKeys());
    }

    function ownerUpdateMascotOk() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(mascotAllowedKeys());
    }

    function ownerUpdatePersonalOk() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(personalAllowedKeys());
    }

    function publicMascotCounterUpdateOk() {
      let oldVisitas = (resource.data.visitas is number) ? resource.data.visitas : 0;
      let oldLikes = (resource.data.likes is number) ? resource.data.likes : 0;
      return resource != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['visitas', 'likes'])
        && request.resource.data.visitas is number
        && request.resource.data.likes is number
        && request.resource.data.visitas >= oldVisitas
        && request.resource.data.visitas <= oldVisitas + 1
        && request.resource.data.likes >= oldLikes
        && request.resource.data.likes <= oldLikes + 1;
    }

    function mascotPerdidaActiva(userId) {
      let p = /databases/$(database)/documents/usuarios/$(userId)/mascot_card/profile;
      return exists(p) && get(p).data.mascotaPerdida == true;
    }

    /** Ping de ubicación desde visitante (sin auth) solo si modo perdido activo. */
    function lostScanCreateOk(userId) {
      return mascotPerdidaActiva(userId)
        && request.resource.data.keys().hasAll(['lat', 'lng', 'at'])
        && request.resource.data.keys().hasOnly(['lat', 'lng', 'at', 'accuracy'])
        && request.resource.data.lat is number
        && request.resource.data.lng is number
        && request.resource.data.lat >= -90.0
        && request.resource.data.lat <= 90.0
        && request.resource.data.lng >= -180.0
        && request.resource.data.lng <= 180.0
        && (!('accuracy' in request.resource.data) || request.resource.data.accuracy is number)
        && request.resource.data.at is timestamp;
    }

    /**
     * Documento raíz: metadatos de cuenta (planes, registro).
     * Lectura autenticada del dueño o pública mínima si otras partes del sistema lo requieren.
     * Ajustá a `allow read: if true` si necesitás lectura pública de metadatos.
     */
    match /usuarios/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    match /usuarios/{userId}/personal_card/{docId} {
      allow read: if true;
      allow create: if isOwner(userId) && personalCardKeysOk();
      allow update: if isOwner(userId) && ownerUpdatePersonalOk();
      allow delete: if isOwner(userId);
    }

    match /usuarios/{userId}/mascot_card/{docId} {
      allow read: if true;
      allow create: if isOwner(userId) && mascotCardKeysOk();
      allow update: if (isOwner(userId) && ownerUpdateMascotOk())
        || (!isOwner(userId) && docId == 'profile' && publicMascotCounterUpdateOk());
      allow delete: if isOwner(userId);
    }

    match /usuarios/{userId}/mascot_lost_scans/{scanId} {
      allow read: if isOwner(userId);
      allow create: if lostScanCreateOk(userId);
      allow update, delete: if isOwner(userId);
    }

    match /mascotas/{mascotaId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /vetPasses/{token} {
      allow read: if resource.data.expiresAt > request.time;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.expiresAt is timestamp;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /petFriendlyPlaces/{placeId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.createdBy == request.auth.uid;
    }
  }
}
