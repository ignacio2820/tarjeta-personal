rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    /** Documento /users/{uid} — membresía y rol (no confundir con usuarios/{uid} tarjetas). */
    function usersMembershipPath(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function isMembershipAdmin() {
      return request.auth != null
        && exists(usersMembershipPath(request.auth.uid))
        && get(usersMembershipPath(request.auth.uid)).data.role == 'admin';
    }

    /** Campos permitidos en /users/{uid} (membresía + productos activos). */
    function membershipProfileKeys() {
      return [
        'email', 'displayName', 'role', 'status', 'createdAt', 'premiumUntil', 'updatedAt',
        'hasEliteCard', 'hasMascotBook', 'activeProducts', 'trialStartDate'
      ];
    }

    /** Documento paralelo /users_elite/{uid} (trial EliteCard / estado lado élite). */
    function usersEliteProfileKeys() {
      return [
        'email', 'displayName', 'role', 'status', 'createdAt', 'premiumUntil', 'updatedAt'
      ];
    }

    function membershipTrialSingleProductOk() {
      return request.resource.data.activeProducts.size() == 1
        && (
          (request.resource.data.hasEliteCard == true
            && request.resource.data.hasMascotBook == false
            && request.resource.data.activeProducts[0] == 'elitecard')
          || (request.resource.data.hasEliteCard == false
            && request.resource.data.hasMascotBook == true
            && request.resource.data.activeProducts[0] == 'mascotbook')
        );
    }

    function membershipTrialDualProductOk() {
      return request.resource.data.activeProducts.size() == 2
        && request.resource.data.hasEliteCard == true
        && request.resource.data.hasMascotBook == true
        && request.resource.data.activeProducts[0] is string
        && request.resource.data.activeProducts[1] is string
        && request.resource.data.activeProducts[0] != request.resource.data.activeProducts[1]
        && (request.resource.data.activeProducts[0] == 'elitecard'
          || request.resource.data.activeProducts[0] == 'mascotbook')
        && (request.resource.data.activeProducts[1] == 'elitecard'
          || request.resource.data.activeProducts[1] == 'mascotbook');
    }

    function membershipTrialProductFieldsOk() {
      return request.resource.data.hasEliteCard is bool
        && request.resource.data.hasMascotBook is bool
        && request.resource.data.activeProducts is list
        && (membershipTrialSingleProductOk() || membershipTrialDualProductOk());
    }

    function membershipTrialStartOk() {
      return !('trialStartDate' in request.resource.data)
        || request.resource.data.trialStartDate is timestamp;
    }

    function mascotAllowedKeys() {
      return [
        'nombre', 'raza', 'sexo', 'salud', 'historia', 'personalidad',
        'mascotId', 'ownerUid', 'ownerEmail', 'email',
        'themeId', 'textureId', 'mascotProTheme', 'tema', 'mascotSurfaceTheme', 'accentColor', 'textColor',
        'fotoPerfilUrl', 'fotoCabeceraUrl', 'galeria', 'galeriaSlots', 'muro',
        'vacunas', 'dueno', 'veterinario', 'fichaCritica', 'visitas', 'likes', 'mascotaPerdida', 'alertaExtravioActiva', 'whatsappUrgencia',
        'updatedAt'
      ];
    }

    function personalAllowedKeys() {
      return [
        'user_nombre', 'user_cargo', 'user_empresa', 'user_bio',
        'user_avatarShape', 'user_buttonLayout', 'user_bgColor', 'user_bgPreset',
        'nombreCompleto', 'cargo', 'empresa', 'redes',
        'email', 'telefono', 'whatsappNumero',
        'fotoUrl', 'logoUrl',
        'vcardNombres', 'vcardApellidos', 'vcardOrganizacion', 'vcardTitulo',
        'bio', 'sitioWeb', 'instagram', 'linkedin', 'mapsUrl', 'calendlyUrl',
        'emailInstitucional',
        'updatedAt'
      ];
    }

    /** Solo claves permitidas en tarjeta profesional (sin campos de mascota). */
    function personalCardKeysOk() {
      return request.resource.data.keys().hasOnly(personalAllowedKeys());
    }

    /** Solo claves permitidas en MascotBook (sin campos profesionales mezclados). */
    function mascotCardKeysOk() {
      return request.resource.data.keys().hasOnly(mascotAllowedKeys());
    }

    function ownerUpdateMascotOk() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(mascotAllowedKeys());
    }

    function ownerUpdatePersonalOk() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(personalAllowedKeys());
    }

    function publicMascotCounterUpdateOk() {
      let oldVisitas = (resource.data.visitas is number) ? resource.data.visitas : 0;
      let oldLikes = (resource.data.likes is number) ? resource.data.likes : 0;
      return resource != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['visitas', 'likes'])
        && request.resource.data.visitas is number
        && request.resource.data.likes is number
        && request.resource.data.visitas >= oldVisitas
        && request.resource.data.visitas <= oldVisitas + 1
        && request.resource.data.likes >= oldLikes
        && request.resource.data.likes <= oldLikes + 1;
    }

    function mascotPerdidaActiva(userId) {
      let p = /databases/$(database)/documents/usuarios/$(userId)/mascot_card/profile;
      return exists(p)
        && (get(p).data.mascotaPerdida == true || get(p).data.alertaExtravioActiva == true);
    }

    function lostAlertOnMascotaDoc(cardId) {
      let m = /databases/$(database)/documents/mascotas/$(cardId);
      return exists(m)
        && (get(m).data.mascotaPerdida == true || get(m).data.alertaExtravioActiva == true);
    }

    /** Ping de ubicación desde visitante (sin auth) solo si modo perdido activo. */
    function lostScanCreateOk(userId) {
      return request.resource.data.keys().hasAll(['lat', 'lng', 'at'])
        && request.resource.data.lat is number
        && request.resource.data.lng is number
        && request.resource.data.lat >= -90.0
        && request.resource.data.lat <= 90.0
        && request.resource.data.lng >= -180.0
        && request.resource.data.lng <= 180.0
        && (!('accuracy' in request.resource.data) || request.resource.data.accuracy is number)
        && request.resource.data.at is timestamp
        && (
          (
            (request.resource.data.keys().hasOnly(['lat', 'lng', 'at'])
              || request.resource.data.keys().hasOnly(['lat', 'lng', 'at', 'accuracy']))
            && mascotPerdidaActiva(userId)
          )
          || (
            (request.resource.data.keys().hasOnly(['lat', 'lng', 'at', 'mascotaCardId'])
              || request.resource.data.keys().hasOnly(['lat', 'lng', 'at', 'accuracy', 'mascotaCardId']))
            && request.resource.data.mascotaCardId is string
            && exists(/databases/$(database)/documents/mascotas/$(request.resource.data.mascotaCardId))
            && get(/databases/$(database)/documents/mascotas/$(request.resource.data.mascotaCardId)).data.ownerUid == userId
            && lostAlertOnMascotaDoc(request.resource.data.mascotaCardId)
          )
        );
    }

    function mascotaDocAuthWriteOk(mascotaId) {
      return request.auth != null
        && (
          (request.resource.data.ownerUid == request.auth.uid)
          || (request.auth.uid == mascotaId && !('ownerUid' in request.resource.data))
        );
    }

    function mascotaDocAuthMutateOk(mascotaId) {
      return request.auth != null
        && (
          (resource.data.keys().hasAny(['ownerUid']) && resource.data.ownerUid == request.auth.uid)
          || (!('ownerUid' in resource.data) && request.auth.uid == mascotaId)
        );
    }

    /** Membresía /users/{uid} — alineado con admin.js checkMascotaAccess (trial 7d + premiumUntil + vencimiento). */
    function mbMembershipData(uid) {
      return exists(usersMembershipPath(uid)) ? get(usersMembershipPath(uid)).data : null;
    }

    function mbMemIsAdmin(m) {
      return m != null && m.keys().hasAny(['role']) && m.role == 'admin';
    }

    function mbMemGlobalSuspendedExpired(m) {
      return m != null && m.keys().hasAny(['status'])
        && (m.status == 'suspended' || m.status == 'expired');
    }

    function mbMemVencimientoPast(m) {
      return m != null
        && m.keys().hasAny(['vencimientoMembresia'])
        && m.vencimientoMembresia is timestamp
        && m.vencimientoMembresia < request.time;
    }

    function mbMemMascotbookInactive(m) {
      return m != null && (
        (m.keys().hasAny(['mascotbook_status'])
          && (m.mascotbook_status == 'inactive' || m.mascotbook_status == 'expired' || m.mascotbook_status == 'suspended'))
        || (m.keys().hasAny(['plan_status'])
          && (m.plan_status == 'inactive' || m.plan_status == 'none' || m.plan_status == 'disabled' || m.plan_status == 'expired'))
      );
    }

    function mbMemPlanPaidGrace(m) {
      return m != null && (
        (m.keys().hasAny(['status']) && (m.status == 'active' || m.status == 'premium' || m.status == 'activo'))
        || (m.keys().hasAny(['mascotbook_status'])
          && (m.mascotbook_status == 'active' || m.mascotbook_status == 'premium' || m.mascotbook_status == 'activo'))
        || (m.keys().hasAny(['plan_status'])
          && (m.plan_status == 'active' || m.plan_status == 'pro' || m.plan_status == 'paid' || m.plan_status == 'premium' || m.plan_status == 'activo'))
        || (m.keys().hasAny(['premiumUntil']) && m.premiumUntil is timestamp && m.premiumUntil > request.time)
      );
    }

    function mbMemTrialStartTs(m) {
      return m != null && (m.keys().hasAny(['trialStartDate']) && m.trialStartDate is timestamp)
        ? m.trialStartDate
        : (m != null && m.keys().hasAny(['createdAt']) && m.createdAt is timestamp ? m.createdAt : null);
    }

    function mbMemTrialExpiredAfterGrace(m) {
      return mbMemTrialStartTs(m) != null
        && request.time > mbMemTrialStartTs(m) + duration.value(7, 'd');
    }

    function mbUserLockedFromMem(m) {
      return !mbMemIsAdmin(m)
        && (
          mbMemGlobalSuspendedExpired(m)
          || mbMemVencimientoPast(m)
          || mbMemMascotbookInactive(m)
          || (!mbMemPlanPaidGrace(m) && mbMemTrialExpiredAfterGrace(m))
        );
    }

    function mbUserMascotbookProContentLocked(uid) {
      return mbMembershipData(uid) != null && mbUserLockedFromMem(mbMembershipData(uid));
    }

    function mbLostActiveData(d) {
      return d != null && (
        (d.keys().hasAny(['mascotaPerdida']) && d.mascotaPerdida == true)
        || (d.keys().hasAny(['alertaExtravioActiva']) && d.alertaExtravioActiva == true)
      );
    }

    function mbMascotLostActivating() {
      return mbLostActiveData(request.resource.data) && !mbLostActiveData(resource.data);
    }

    function mbMascotSensitiveKeysTouch(diff) {
      return diff.changedKeys().hasAny([
        'salud', 'vacunas', 'veterinario', 'fichaCritica', 'fotoPerfilUrl', 'fotoCabeceraUrl',
        'galeria', 'galeriaSlots', 'muro'
      ]);
    }

    function mbMascotaOwnerUidForWrite() {
      return resource.data.keys().hasAny(['ownerUid']) && resource.data.ownerUid is string
        ? resource.data.ownerUid
        : request.auth.uid;
    }

    function mbMascotbookWriteForbidden(uid) {
      return mbUserMascotbookProContentLocked(uid)
        && (
          mbMascotSensitiveKeysTouch(request.resource.data.diff(resource.data))
          || mbMascotLostActivating()
        );
    }

    function mbMascotCreateTouchesLockedFields() {
      return request.resource.data.keys().hasAny([
        'salud', 'vacunas', 'veterinario', 'fichaCritica', 'fotoPerfilUrl', 'fotoCabeceraUrl',
        'galeria', 'galeriaSlots', 'muro', 'mascotaPerdida', 'alertaExtravioActiva', 'whatsappUrgencia'
      ]);
    }

    /**
     * /users — membresía: solo dueño o admin lee cada doc; queries a la colección solo devuelven filas permitidas (admin ve todas).
     * Alta: el usuario crea su doc con role user y status trial.
     * /usuarios — tarjetas y metadatos legacy; lectura pública del doc raíz para flujos existentes.
     */
    match /users/{userId} {
      allow read: if request.auth != null && (isOwner(userId) || isMembershipAdmin());
      allow create: if request.auth != null
        && isOwner(userId)
        && request.resource.data.keys().hasAll(['email', 'role', 'status', 'createdAt', 'premiumUntil'])
        && request.resource.data.keys().hasOnly(membershipProfileKeys())
        && request.resource.data.role == 'user'
        && request.resource.data.status == 'trial'
        && membershipTrialProductFieldsOk()
        && membershipTrialStartOk();
      allow update: if isMembershipAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(membershipProfileKeys());
      /** El dueño puede pasar a expired cuando ya venció premiumUntil (sincroniza estado en cliente). */
      allow update: if request.auth != null
        && isOwner(userId)
        && request.resource.data.status == 'expired'
        && resource.data.status != 'expired'
        && resource.data.premiumUntil is timestamp
        && resource.data.premiumUntil < request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(membershipProfileKeys());
      allow update: if request.auth != null
        && isOwner(userId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['email', 'displayName', 'updatedAt'])
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status
        && request.resource.data.premiumUntil == resource.data.premiumUntil
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isMembershipAdmin();
    }

    /**
     * /users_elite/{uid} — estado de membresía EliteCard (sidecar).
     * Alta: el usuario autenticado crea su doc (mismo patrón que /users).
     */
    match /users_elite/{userId} {
      allow read: if request.auth != null && (isOwner(userId) || isMembershipAdmin());
      allow create: if request.auth != null
        && isOwner(userId)
        && request.resource.data.keys().hasAll(['email', 'role', 'status', 'createdAt', 'premiumUntil'])
        && request.resource.data.keys().hasOnly(usersEliteProfileKeys())
        && request.resource.data.role == 'user'
        && request.resource.data.status == 'trial';
      allow update: if isMembershipAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(usersEliteProfileKeys());
      allow update: if request.auth != null
        && isOwner(userId)
        && request.resource.data.status == 'expired'
        && resource.data.status != 'expired'
        && resource.data.premiumUntil is timestamp
        && resource.data.premiumUntil < request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(usersEliteProfileKeys());
      allow update: if request.auth != null
        && isOwner(userId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['email', 'displayName', 'updatedAt'])
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status
        && request.resource.data.premiumUntil == resource.data.premiumUntil
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isMembershipAdmin();
    }

    match /usuarios/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    /**
     * tarjetas — índice de tarjetas por cuenta (varias MascotBook / EliteCard por mismo dueño).
     * ownerEmail + ownerUid replicados desde Auth; publicCardId = id público en URL / mascotas/{id}.
     */
    match /tarjetas/{tarjetaId} {
      allow read: if request.auth != null && resource.data.ownerUid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerEmail is string
        && request.resource.data.mascotaNombre is string
        && request.resource.data.publicCardId is string
        && request.resource.data.tipo is string;
      allow update: if request.auth != null
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == resource.data.ownerUid;
      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }

    match /usuarios/{userId}/personal_card/{docId} {
      allow read: if true;
      allow create: if isOwner(userId) && personalCardKeysOk();
      allow update: if isOwner(userId) && ownerUpdatePersonalOk();
      allow delete: if isOwner(userId);
    }

    match /usuarios/{userId}/mascot_card/{docId} {
      allow read: if true;
      allow create: if isOwner(userId) && mascotCardKeysOk();
      allow update: if (!isOwner(userId) && docId == 'profile' && publicMascotCounterUpdateOk())
        || (
          isOwner(userId)
          && ownerUpdateMascotOk()
          && !mbMascotbookWriteForbidden(userId)
        );
      allow delete: if isOwner(userId);
    }

    match /usuarios/{userId}/mascot_lost_scans/{scanId} {
      allow read: if isOwner(userId);
      allow create: if lostScanCreateOk(userId);
      allow update, delete: if isOwner(userId);
    }

    /**
     * mascotas — lectura pública sin condiciones de ID ni auth (descarta bloqueos silenciosos en lectura).
     * Escritura: dueño autenticado o actualización pública de contadores visitas/likes.
     */
    match /mascotas/{mascotaId} {
      allow read: if true;
      allow create: if mascotaDocAuthWriteOk(mascotaId)
        && (!mbUserMascotbookProContentLocked(request.auth.uid) || !mbMascotCreateTouchesLockedFields());
      allow delete: if mascotaDocAuthMutateOk(mascotaId);
      allow update: if publicMascotCounterUpdateOk()
        || (
          mascotaDocAuthMutateOk(mascotaId)
          && !mbMascotbookWriteForbidden(mbMascotaOwnerUidForWrite())
        );
    }

    match /vetPasses/{token} {
      allow read: if resource.data.expiresAt > request.time;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.expiresAt is timestamp;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /petFriendlyPlaces/{placeId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.createdBy == request.auth.uid;
    }
  }
}
