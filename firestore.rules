rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * WebElite — colección `usuarios`
     * - Lectura pública: la tarjeta (index.html) lee el documento sin autenticación.
     * - Escritura: solo el usuario autenticado cuyo uid coincide con el ID del documento
     *   (mismo modelo que admin.html: usuarios/{uid}).
     */
    match /usuarios/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    /**
     * Pase veterinario temporal (48 h): lectura pública solo si no expiró.
     */
    match /vetPasses/{token} {
      allow read: if resource.data.expiresAt > request.time;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.expiresAt is timestamp;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    /** Puntos pet-friendly recomendados (mapa comunidad). */
    match /petFriendlyPlaces/{placeId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.createdBy == request.auth.uid;
    }
  }
}
